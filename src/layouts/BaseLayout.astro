---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { useTranslations, localizePath } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Evoque – Yourself: psychologisches Persönlichkeitsentwicklungs-Coaching für nachhaltige Zielerreichung. Coaching, keine Psychotherapie.',
} = Astro.props;

const lang = (Astro.currentLocale ?? 'de') as 'de' | 'en';
const t = useTranslations(lang);

const fullTitle = `${title} · EVOQUE yourself`;

// hreflang-Alternativen für beide Sprachen
const site = Astro.site?.origin ?? '';
const pathDe = localizePath(Astro.url.pathname, 'de');
const pathEn = localizePath(Astro.url.pathname, 'en');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/images/Logos/0_logo.png" />

    <!-- Sprach-Alternativen (SEO) -->
    <link rel="alternate" hreflang="de" href={site + pathDe} />
    <link rel="alternate" hreflang="en" href={site + pathEn} />
    <link rel="alternate" hreflang="x-default" href={site + pathDe} />

    <!-- Schriften: Playfair Display (Überschriften) + Jost (alles andere) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Jost:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">{t('skip.toContent')}</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
