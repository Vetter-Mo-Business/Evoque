---
interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  image: string;
  imageAlt: string;
  ctaHref: string;
  ctaLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  eyebrow,
  title,
  text,
  image,
  imageAlt,
  ctaHref,
  ctaLabel,
  secondaryHref,
  secondaryLabel,
} = Astro.props;
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="lead hero__text">{text}</p>
      <div class="hero__actions">
        <a href={ctaHref} class="btn btn--primary">{ctaLabel}</a>
        {
          secondaryHref && secondaryLabel && (
            <a href={secondaryHref} class="btn btn--secondary">
              {secondaryLabel}
            </a>
          )
        }
      </div>
    </div>
    <div class="hero__media">
      <img src={image} alt={imageAlt} width="640" height="800" loading="eager" />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-2xl) var(--space-3xl);
  }
  .hero__inner {
    display: grid;
    gap: var(--space-2xl);
    align-items: center;
  }
  @media (min-width: 860px) {
    .hero__inner {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }
  .hero__text {
    max-width: 46ch;
    color: var(--forest-deep);
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }
  .hero__media img {
    width: 100%;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    object-fit: cover;
    aspect-ratio: 4 / 5;
  }
</style>
