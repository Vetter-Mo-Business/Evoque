---
interface Props {
  video?: string;
  poster?: string;
  title?: string;
  ctaHref?: string;
  ctaLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  video = '/images/Animation/Hero_Video-2.mp4',
  poster,
  title = 'Become your\nbest you',
  ctaHref,
  ctaLabel,
  secondaryHref,
  secondaryLabel,
} = Astro.props;
---

<section class="hero">
  <div class="hero__stage">
    <video
      class="hero__video"
      src={video}
      poster={poster}
      autoplay
      muted
      playsinline
      preload="auto"
      data-loop-tail="6"
    ></video>

    <div class="hero__overlay">
      <div class="hero__content">
        <h1 class="hero__title" set:html={title.replace(/\n/g, '<br />')} />
        {
          (ctaHref && ctaLabel) || (secondaryHref && secondaryLabel) ? (
            <div class="hero__actions">
              {secondaryHref && secondaryLabel && (
                <a href={secondaryHref} class="btn btn--secondary hero__btn">
                  {secondaryLabel}
                </a>
              )}
              {ctaHref && ctaLabel && (
                <a href={ctaHref} class="btn btn--primary hero__btn">
                  {ctaLabel}
                </a>
              )}
            </div>
          ) : null
        }
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    /* =================================================================
       HIER ANPASSEN
       Alle Werte skalieren mit der Videobreite (cqw = 1% der Videobreite).
       Dadurch bleibt der Text auf JEDEM Bildschirm gleich groß im
       Verhältnis zum Blumenkranz – also immer mittig innerhalb davon.
       ================================================================= */

    /* Maximale Breite des Videos.
       100% = volle Bildschirmbreite. Für kleiner z.B. 1040px setzen. */
    --hero-max-width: 100%;

    /* Höhe der Hero-Sektion. Das Video wird oben/unten passend
       beschnitten (object-fit: cover), um genau diese Höhe zu füllen,
       ohne das Seitenverhältnis zu verzerren.
       Standard: erster Bildschirm abzüglich Navbar-Höhe (76px). */
    --hero-height: calc(100svh - 76px);

    /* Schriftgröße der Überschrift "Become your best you".
       clamp(min, fließend, max): mittlerer Wert in cqw steuert die Größe.
       Der min-Wert ist klein, damit die Schrift beim Verkleinern des
       Bildschirms wirklich weiter mitschrumpft. */
    --hero-text-size: clamp(0.85rem, 6.2cqw, 4.4rem);

    /* Textfarbe der Überschrift (Dunkelgrün) */
    --hero-text-color: var(--forest-deep);

    /* Breite des Textblocks – hält den Text innerhalb des Blumenkranzes.
       Greift, sobald der Text umbricht (kleine Bildschirme). */
    --hero-content-width: 60cqw;

    /* Abstand zwischen Überschrift und Buttons (Buttons höher/tiefer) */
    --hero-actions-gap: 6cqw;

    /* Größe der Buttons (Schrift) – skaliert ebenfalls mit dem Video.
       Kleiner min-Wert, damit die Buttons mitschrumpfen. */
    --hero-btn-size: clamp(0.55rem, 1.9cqw, 1.1rem);

    /* Horizontale Verschiebung von Text + Buttons (− links / + rechts) */
    --hero-text-x: 0px;

    /* Vertikale Verschiebung von Text + Buttons (− nach oben / + nach unten).
       In cqw, damit sie proportional zum Video bleibt. Hier nachjustieren,
       um alles minimal höher/tiefer zu rücken. */
    --hero-text-y: 3cqw;

    /* =================================================================
       Ab hier in der Regel nichts mehr ändern
       ================================================================= */

    overflow: hidden;
  }

  /* Bühne hält das 16:9-Verhältnis, ist zentriert und begrenzt */
  .hero__stage {
    position: relative;
    width: 100%;
    max-width: var(--hero-max-width);
    margin-inline: auto;
    height: var(--hero-height);
    overflow: hidden;
    background: var(--forest-deep, #0f1f17);
    /* macht cqw-Einheiten relativ zur Videobreite verfügbar */
    container-type: inline-size;
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Zentrierte Text-Ebene über dem Video */
  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translate(var(--hero-text-x), var(--hero-text-y));
    pointer-events: none;
  }

  .hero__content {
    /* Im Normalfall keine Breitenbegrenzung: der einzeilige Titel wird so
       von Flexbox sauber exakt in die Mitte gesetzt (Buttons rücken mit). */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--hero-actions-gap);
    text-align: center;
  }

  .hero__title {
    margin: 0;
    color: var(--hero-text-color);
    font-size: var(--hero-text-size);
    line-height: 1.05;
    /* Standard (breites Video): einzeilig */
    white-space: nowrap;
    /* sanfter heller Schein für Lesbarkeit auf dem Video */
    text-shadow: 0 0.3cqw 2cqw rgba(255, 255, 255, 0.55);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 2cqw;
    justify-content: center;
  }

  /* Wird das Video (= der Kranz) schmal, bricht der Text auf 2 Zeilen
     um und die Buttons stehen untereinander – alles bleibt mittig. */
  @container (max-width: 680px) {
    .hero__content {
      /* erst beim Umbruch begrenzen, damit der Text im Kranz bleibt */
      max-width: var(--hero-content-width);
    }
    .hero__title {
      white-space: normal;
    }
    .hero__actions {
      flex-direction: column;
      align-items: center;
    }
    .hero__btn {
      /* nur so breit wie das Wort darin – schrumpft mit */
      width: auto;
    }
  }

  /* Auf schmalen Bildschirmen das volle 16:9 zeigen, statt seitlich
     stark zu beschneiden – so bleibt der ganze Blumenkranz sichtbar. */
  @media (max-width: 680px) {
    .hero__stage {
      height: auto;
      aspect-ratio: 16 / 9;
    }
  }

  /* Buttons skalieren mit dem Video */
  .hero__btn {
    pointer-events: auto;
    font-size: var(--hero-btn-size);
    padding: 0.9em 1.8em;
  }
</style>

<script>
  // Endlos weiterlaufen, OHNE Neustart von vorne:
  // Das Video spielt einmal komplett. Danach springt es nur noch an den
  // Anfang der letzten Sekunden zurück, sodass sich die Blumen ruhig
  // weiterbewegen – ohne "Video zu Ende"-Gefühl.
  document.querySelectorAll<HTMLVideoElement>('.hero__video').forEach((v) => {
    const tail = parseFloat(v.dataset.loopTail || '6'); // letzte Sekunden
    v.loop = false;

    // Autoplay zuverlässig anstoßen. Auf einer frisch deployten Domain
    // ist die Autoplay-Richtlinie strenger als lokal – darum erzwingen wir
    // den stummen Zustand und versuchen das Abspielen mehrfach.
    v.muted = true;
    v.defaultMuted = true;
    v.setAttribute('muted', '');

    const tryPlay = () => {
      const p = v.play();
      if (p) p.catch(() => {});
    };

    tryPlay();
    v.addEventListener('loadeddata', tryPlay, { once: true });
    v.addEventListener('canplay', tryPlay, { once: true });

    // Letzter Fallback: sollte der Browser den Start blockieren, startet
    // das Video bei der ersten Interaktion des Besuchers.
    const onInteract = () => {
      tryPlay();
      window.removeEventListener('pointerdown', onInteract);
      window.removeEventListener('touchstart', onInteract);
      window.removeEventListener('scroll', onInteract);
    };
    window.addEventListener('pointerdown', onInteract, { passive: true });
    window.addEventListener('touchstart', onInteract, { passive: true });
    window.addEventListener('scroll', onInteract, { passive: true });

    v.addEventListener('ended', () => {
      const start = Math.max(0, (v.duration || tail) - tail);
      v.currentTime = start;
      tryPlay();
    });
  });
</script>
