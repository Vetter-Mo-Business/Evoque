---
interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  image: string;
  imageAlt: string;
  ctaHref: string;
  ctaLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  eyebrow,
  title,
  text,
  image,
  imageAlt,
  ctaHref,
  ctaLabel,
  secondaryHref,
  secondaryLabel,
} = Astro.props;
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__media">
      <span class="hero__glow" aria-hidden="true"></span>
      <img src={image} alt={imageAlt} width="640" height="800" loading="eager" />
      <span class="hero__shine" aria-hidden="true"></span>
    </div>

    <div class="hero__content">
      {eyebrow && <p class="eyebrow hero__eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="lead hero__text">{text}</p>
      <div class="hero__actions">
        <a href={ctaHref} class="btn btn--primary">{ctaLabel}</a>
        {
          secondaryHref && secondaryLabel && (
            <a href={secondaryHref} class="btn btn--secondary">
              {secondaryLabel}
            </a>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-xl);
    overflow: hidden;
  }
  .hero__inner {
    display: grid;
    gap: var(--space-2xl);
    align-items: center;
  }
  @media (min-width: 860px) {
    .hero__inner {
      /* Bild links, Text rechts – Höhe der Sektion = Höhe des Bildes */
      grid-template-columns: 0.92fr 1.08fr;
      gap: var(--space-3xl);
    }
  }

  /* ---------- Bild + Eye-Catcher ---------- */
  .hero__media {
    position: relative;
    isolation: isolate;
  }
  .hero__media img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    animation: hero-float 9s ease-in-out infinite;
  }

  /* Weicher, atmender Schein hinter dem Bild – organisch, ruhig */
  .hero__glow {
    position: absolute;
    inset: -10%;
    z-index: 0;
    border-radius: 50%;
    background: radial-gradient(
      closest-side,
      rgba(172, 191, 175, 0.6),
      rgba(172, 191, 175, 0) 72%
    );
    filter: blur(26px);
    animation: hero-glow 8s ease-in-out infinite;
    pointer-events: none;
  }

  /* Sanfter Licht-Sweep, der einmalig über das Bild gleitet */
  .hero__shine {
    position: absolute;
    inset: 0;
    z-index: 2;
    border-radius: var(--radius-lg);
    overflow: hidden;
    pointer-events: none;
  }
  .hero__shine::before {
    content: '';
    position: absolute;
    top: -40%;
    left: -60%;
    width: 40%;
    height: 180%;
    transform: rotate(18deg);
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.35) 50%,
      rgba(255, 255, 255, 0) 100%
    );
    animation: hero-shine 7s ease-in-out 1.2s infinite;
  }

  /* ---------- Text ---------- */
  .hero__text {
    max-width: 48ch;
    color: var(--forest-deep);
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  /* Sanftes Eintauchen der Textzeilen */
  .hero__content > * {
    animation: hero-rise 0.7s ease both;
  }
  .hero__eyebrow {
    animation-delay: 0.05s;
  }
  .hero__content h1 {
    animation-delay: 0.16s;
  }
  .hero__text {
    animation-delay: 0.3s;
  }
  .hero__actions {
    animation-delay: 0.42s;
  }

  @keyframes hero-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }
  @keyframes hero-glow {
    0%,
    100% {
      opacity: 0.5;
      transform: scale(1);
    }
    50% {
      opacity: 0.85;
      transform: scale(1.08);
    }
  }
  @keyframes hero-shine {
    0% {
      left: -60%;
    }
    35%,
    100% {
      left: 130%;
    }
  }
  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__media img,
    .hero__glow,
    .hero__shine::before,
    .hero__content > * {
      animation: none;
    }
  }
</style>
