---
import { useTranslations, localizePath, type Lang } from '../i18n/ui';

const year = 2026;
const lang = (Astro.currentLocale ?? 'de') as Lang;
const t = useTranslations(lang);
const l = (p: string) => localizePath(p, lang);
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <img
        src="/images/Logos/0_logo.png"
        alt="EVOQUE Yourself – Coaching"
        width="120"
        height="120"
        class="site-footer__logo"
      />
      <p class="site-footer__tagline">
        {t('footer.tagline')}
      </p>
    </div>

    <nav class="site-footer__nav" aria-label={t('footer.pages')}>
      <h2 class="site-footer__heading">{t('footer.pages')}</h2>
      <ul>
        <li><a href={l('/ueber-mich')}>{t('footer.about')}</a></li>
        <li><a href={l('/coaching')}>{t('footer.coaching')}</a></li>
        <li><a href={l('/kontakt')}>{t('footer.contact')}</a></li>
      </ul>
    </nav>

    <nav class="site-footer__nav" aria-label={t('footer.legal')}>
      <h2 class="site-footer__heading">{t('footer.legal')}</h2>
      <ul>
        <li><a href={l('/impressum')}>{t('footer.imprint')}</a></li>
        <li><a href={l('/datenschutz')}>{t('footer.privacy')}</a></li>
        <li><a href={l('/kontakt')}>{t('footer.contactShort')}</a></li>
      </ul>
    </nav>
  </div>

  <div class="container site-footer__credit-row">
    <span class="site-footer__credit">
      {t('footer.credit')}
      <img
        src="/images/github.png"
        alt="VeMo IT &amp; Design"
        width="18"
        height="18"
        class="site-footer__credit-logo"
        loading="lazy"
      />
    </span>
  </div>

  <div class="site-footer__bar">
    <div class="container site-footer__bar-inner">
      <p class="site-footer__note">
        {t('footer.note')}
      </p>
      <p class="site-footer__copy">
        © {year} {t('footer.copy')}
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--forest-deep);
    color: var(--on-dark);
    margin-top: var(--space-3xl);
  }
  .site-footer__inner {
    display: grid;
    gap: var(--space-xl);
    padding-block: var(--space-2xl);
  }
  @media (min-width: 760px) {
    .site-footer__inner {
      grid-template-columns: 1.6fr 1fr 1fr;
      gap: var(--space-2xl);
    }
  }
  .site-footer__logo {
    width: 110px;
    height: auto;
    border-radius: var(--radius);
    margin-bottom: var(--space-md);
  }
  .site-footer__tagline {
    color: var(--sage-harmony);
    max-width: 32ch;
    margin: 0;
  }
  .site-footer__heading {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--sage-harmony);
    margin: 0 0 var(--space-md);
  }
  .site-footer__nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-sm);
  }
  .site-footer__nav a {
    color: var(--on-dark);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
  }
  .site-footer__nav a:hover {
    border-bottom-color: var(--sage-harmony);
  }

  .site-footer__bar {
    border-top: 1px solid rgba(172, 191, 175, 0.25);
  }
  .site-footer__bar-inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm) var(--space-lg);
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-lg);
  }
  .site-footer__note,
  .site-footer__copy {
    margin: 0;
    font-size: 0.85rem;
    color: var(--sage-harmony);
  }

  /* Kooperations-Hinweis: bewusst sehr dezent, zurückhaltend.
     Sitzt über der Copyright-Linie, auf Container-Breite. */
  .site-footer__credit-row {
    display: flex;
    justify-content: flex-end;
    padding-bottom: var(--space-md);
  }
  .site-footer__credit {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: 0.72rem;
    color: var(--sage-harmony);
    opacity: 0.6;
  }
  .site-footer__credit-logo {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    flex-shrink: 0;
  }
</style>
