---
interface Step {
  num: string;
  title: string;
  text: string;
}

const steps: Step[] = [
  {
    num: '01',
    title: 'Kennenlerngespräch',
    text: 'Problem klären: was, wann, wo, wie lange – und warum. Wir schauen gemeinsam, worum es wirklich geht.',
  },
  {
    num: '02',
    title: 'Zweites Gespräch',
    text: 'Wir vertiefen das Bild und verstehen den Ursprung des Themas.',
  },
  {
    num: '03',
    title: 'Ziel festlegen',
    text: 'Wir bestimmen dein Ziel und den Weg dorthin.',
  },
  {
    num: '04 – 07',
    title: 'Schritt für Schritt zum Ziel',
    text: 'Begleitete Etappen: Veränderung im Hier und Jetzt, in deinem Tempo – ich bleibe dein Anker.',
  },
];
---

<ol class="process-path">
  {
    steps.map((step) => (
      <li class="process-step">
        <span class="process-step__num">{step.num}</span>
        <div class="process-step__body">
          <h3 class="process-step__title">{step.title}</h3>
          <p class="process-step__text">{step.text}</p>
        </div>
      </li>
    ))
  }
</ol>

<style>
  .process-path {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
    display: grid;
    gap: var(--space-lg);
  }
  /* Vertikale Verbindungslinie als visueller Pfad */
  .process-path::before {
    content: '';
    position: absolute;
    left: 27px;
    top: 28px;
    bottom: 28px;
    width: 2px;
    background: var(--sage-harmony);
  }
  .process-step {
    position: relative;
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: var(--space-lg);
    align-items: start;
  }
  .process-step__num {
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 56px;
    height: 56px;
    padding-inline: 0.4em;
    border-radius: 999px;
    background: var(--forest-deep);
    color: var(--on-dark);
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .process-step__body {
    background: #fff;
    border-radius: var(--radius);
    border: var(--border-soft);
    padding: var(--space-lg) var(--space-xl);
    box-shadow: var(--shadow-soft);
  }
  .process-step__title {
    margin-bottom: var(--space-2xs);
  }
  .process-step__text {
    margin: 0;
    color: var(--calm-earth);
  }
</style>
