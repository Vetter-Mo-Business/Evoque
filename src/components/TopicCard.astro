---
interface Props {
  title: string;
  placeholder?: boolean;
}
const { title, placeholder = false } = Astro.props;
---

<article class={`topic-card ${placeholder ? 'topic-card--placeholder' : ''}`}>
  <div class="topic-card__media" aria-hidden="true"><slot name="icon" /></div>
  <div class="topic-card__body">
    <h3 class="topic-card__title">{title}</h3>
    <p class="topic-card__text"><slot /></p>
  </div>
</article>

<style>
  .topic-card {
    /* ===================== HIER ANPASSEN =====================
       Höhe des Bild-Banners oben in der Karte. */
    --topic-media-height: 150px;
    /* ========================================================= */

    background: #fff;
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
    border: var(--border-soft);
    height: 100%;
    /* sorgt dafür, dass das Bild oben sauber an den runden Ecken endet */
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .topic-card--placeholder {
    background: var(--soft-sand);
    border-style: dashed;
  }

  /* Bild-Banner über die ganze Kartenbreite, ganz oben */
  .topic-card__media {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: var(--topic-media-height);
    background: var(--sage-harmony);
    color: var(--forest-deep);
    overflow: hidden;
  }
  /* Echtes Bild füllt den Banner komplett aus */
  .topic-card__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* Platzhalter-Icon wird mittig im Banner gezeigt */
  .topic-card__media :global(svg) {
    width: 56px;
    height: 56px;
  }

  .topic-card__body {
    padding: var(--space-xl);
  }
  .topic-card__title {
    margin-bottom: var(--space-xs);
  }
  .topic-card__text {
    margin: 0;
    color: var(--calm-earth);
  }
</style>
