---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import BookingEmbed from '../components/BookingEmbed.astro';

// Cal.com-Buchungslink im Format "benutzername/event-typ" eintragen.
// Beispiel: 'malin-evoque/kennenlernen'. Leer lassen -> Platzhalter wird angezeigt.
// Einrichtungs-Anleitung steht in src/components/BookingEmbed.astro.
const CAL_LINK = 'tim-vetter-6ryc7s/kennenlerngesprach';
---

<BaseLayout
  title="Kontakt & Buchung"
  description="Buche dein kostenloses Kennenlerngespräch oder nimm direkt Kontakt zu Evoque auf."
>
  <!-- Intro -->
  <section class="section section--tight">
    <div class="container container--narrow center">
      <p class="eyebrow">Kontakt & Buchung</p>
      <h1>Lass uns kennenlernen.</h1>
      <p class="lead">
        Buche dein kostenloses Kennenlerngespräch oder schreib mir direkt – ich freue
        mich, von dir zu hören.
      </p>
    </div>
  </section>

  <!-- Online-Buchungskalender -->
  <section class="section section--tight">
    <div class="container">
      <div class="booking-wrap">
        <SectionHeading eyebrow="Online buchen" title="Termin direkt sichern" />
        <BookingEmbed calLink={CAL_LINK} />
      </div>
    </div>
  </section>

  <!-- Kontaktiere mich direkt -->
  <section class="section section--tight">
    <div class="container container--narrow">
      <h2 class="contact-direct__title">Kontaktiere mich direkt</h2>
      <dl class="contact-list">
        <div>
          <dt>E-Mail</dt>
          <dd>
            <a href="mailto:evoqueyourself.coaching@gmail.com"
              >evoqueyourself.coaching@gmail.com</a
            >
            <span class="contact-note">[PLATZHALTER: finale E-Mail-Adresse bestätigen]</span>
          </dd>
        </div>
        <div>
          <dt>Telefon</dt>
          <dd>[PLATZHALTER: Telefonnummer]</dd>
        </div>
      </dl>

      <div class="contact-card-visual">
        <img
          src="/images/Business Card/D50B700E-D3AF-45D6-AE41-8177F56A4E42.PNG"
          alt="Visitenkarte von Evoque – Vorderseite"
          width="400"
          height="250"
        />
        <img
          src="/images/Business Card/E2650570-2C2A-47F4-80A1-1A3D0E119117.PNG"
          alt="Visitenkarte von Evoque – Rückseite"
          width="400"
          height="250"
        />
      </div>
    </div>
  </section>

  <!-- Rechtliches: Anrisse -->
  <section class="section surface-sand">
    <div class="container">
      <div class="grid grid--2">
        <article class="card legal-teaser">
          <h2>Impressum</h2>
          <p class="text-muted">[PLATZHALTER: Impressumsdaten – Kurzangabe]</p>
          <a href="/impressum" class="btn btn--primary">Zum Impressum</a>
        </article>
        <article class="card legal-teaser">
          <h2>Datenschutz</h2>
          <p class="text-muted">
            [PLATZHALTER: Datenschutzerklärung – Kurzangabe]
          </p>
          <a href="/datenschutz" class="btn btn--primary">Zur Datenschutzerklärung</a>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-direct__title {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .contact-list {
    margin: 0 auto var(--space-2xl);
    display: grid;
    gap: var(--space-lg);
    justify-items: center;
    text-align: center;
  }
  .contact-list dt {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--calm-earth);
    margin-bottom: var(--space-2xs);
  }
  .contact-list dd {
    margin: 0;
    font-size: 1.1rem;
  }
  .contact-list a {
    color: var(--forest-deep);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .contact-note {
    display: block;
    font-size: 0.82rem;
    color: var(--calm-earth);
  }

  .contact-card-visual {
    display: grid;
    gap: var(--space-md);
  }
  @media (min-width: 640px) {
    .contact-card-visual {
      grid-template-columns: 1fr 1fr;
    }
  }
  .contact-card-visual img {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
    border: var(--border-soft);
  }

  .legal-teaser h2 {
    margin-bottom: var(--space-sm);
  }
</style>
