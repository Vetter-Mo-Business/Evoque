---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import BookingEmbed from '../components/BookingEmbed.astro';
import portraitImg from '../assets/about/DSC00751.jpg';

// Cal.com-Buchungslink im Format "benutzername/event-typ" eintragen.
// Beispiel: 'malin-evoque/kennenlernen'. Leer lassen -> Platzhalter wird angezeigt.
// Einrichtungs-Anleitung steht in src/components/BookingEmbed.astro.
const CAL_LINK = 'tim-vetter-6ryc7s/kennenlerngesprach';

const lang = (Astro.currentLocale ?? 'de') as 'de' | 'en';
const content = {
  de: {
    metaTitle: 'Kontakt & Buchung',
    metaDesc: 'Buche dein kostenloses Kennenlerngespräch oder nimm direkt Kontakt zu Evoque auf.',
    introEyebrow: 'Kontakt & Buchung',
    introTitle: 'Lass uns kennenlernen.',
    introLead:
      'Buche dein kostenloses Kennenlerngespräch oder kontaktiere mich direkt – ich freue mich, von dir zu hören!',
    bookEyebrow: 'Online buchen',
    bookTitle: 'Termin direkt sichern',
    directTitle: 'Kontaktiere mich direkt',
    email: 'E-Mail',
    emailNote: '[PLATZHALTER: finale E-Mail-Adresse bestätigen]',
    phone: 'Telefon',
    phoneValue: '[PLATZHALTER: Telefonnummer]',
    portraitAlt: 'Malin – Evoque',
    cardAlt: 'Visitenkarte von Evoque – Vorderseite',
  },
  en: {
    metaTitle: 'Contact & Booking',
    metaDesc: 'Book your free intro call or get in touch with Evoque directly.',
    introEyebrow: 'Contact & Booking',
    introTitle: 'Let’s get to know each other.',
    introLead:
      'Book your free intro call or contact me directly – I look forward to hearing from you!',
    bookEyebrow: 'Book online',
    bookTitle: 'Secure your appointment directly',
    directTitle: 'Contact me directly',
    email: 'Email',
    emailNote: '[PLACEHOLDER: confirm final email address]',
    phone: 'Phone',
    phoneValue: '[PLACEHOLDER: phone number]',
    portraitAlt: 'Malin – Evoque',
    cardAlt: 'Evoque business card – front',
  },
}[lang];
---

<BaseLayout title={content.metaTitle} description={content.metaDesc}>
  <!-- Intro -->
  <section class="section section--tight">
    <div class="container container--narrow center">
      <p class="eyebrow">{content.introEyebrow}</p>
      <h1>{content.introTitle}</h1>
      <p class="lead">{content.introLead}</p>
    </div>
  </section>

  <!-- Online-Buchungskalender -->
  <section class="section section--tight">
    <div class="container">
      <div class="booking-wrap">
        <SectionHeading eyebrow={content.bookEyebrow} title={content.bookTitle} />
        <BookingEmbed calLink={CAL_LINK} />
      </div>
    </div>
  </section>

  <!-- Kontaktiere mich direkt -->
  <section class="section section--tight">
    <div class="container">
      <h2 class="contact-direct__title">{content.directTitle}</h2>

      <div class="contact-box">
        <div class="contact-direct">
        <article class="card contact-person">
          <div class="contact-person__avatar">
            <Image
              src={portraitImg}
              alt={content.portraitAlt}
              widths={[300, 480]}
              sizes="150px"
              quality={85}
              loading="lazy"
            />
          </div>
          <dl class="contact-list">
            <div>
              <dt>{content.email}</dt>
              <dd>
                <a href="mailto:evoqueyourself.coaching@gmail.com"
                  >evoqueyourself.coaching@gmail.com</a
                >
                <span class="contact-note">{content.emailNote}</span>
              </dd>
            </div>
            <div>
              <dt>{content.phone}</dt>
              <dd>{content.phoneValue}</dd>
            </div>
          </dl>
        </article>

        <div class="contact-card-visual">
          <img
            src="/images/Business Card/D50B700E-D3AF-45D6-AE41-8177F56A4E42.PNG"
            alt={content.cardAlt}
            width="400"
            height="250"
          />
        </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .contact-direct__title {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  /* Große Box rund um den ganzen Direktkontakt-Bereich */
  .contact-box {
    background: var(--soft-sand);
    border: var(--border-soft);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    padding: var(--space-2xl);
  }

  /* Zwei Spalten: links Personen-Karte, rechts Visitenkarte */
  .contact-direct {
    display: grid;
    gap: var(--space-xl);
    align-items: center;
  }
  @media (min-width: 760px) {
    .contact-direct {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Linke Karte mit Foto-Kreis oben */
  .contact-person {
    text-align: center;
    display: grid;
    gap: var(--space-lg);
    justify-items: center;
  }
  .contact-person__avatar {
    width: 140px;
    height: 140px;
    border-radius: 999px;
    overflow: hidden;
    border: 3px solid var(--sage-harmony);
    box-shadow: var(--shadow-soft);
  }
  .contact-person__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .contact-list {
    margin: 0;
    display: grid;
    gap: var(--space-lg);
    justify-items: center;
    text-align: center;
  }
  .contact-list dt {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--calm-earth);
    margin-bottom: var(--space-2xs);
  }
  .contact-list dd {
    margin: 0;
    font-size: 1.1rem;
  }
  .contact-list a {
    color: var(--forest-deep);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .contact-note {
    display: block;
    font-size: 0.82rem;
    color: var(--calm-earth);
  }

  .contact-card-visual {
    display: flex;
    justify-content: center;
  }
  .contact-card-visual img {
    width: 100%;
    max-width: 400px;
    height: auto;
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
    border: var(--border-soft);
  }
</style>
