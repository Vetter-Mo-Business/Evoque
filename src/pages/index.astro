---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TopicCard from '../components/TopicCard.astro';
import Testimonial from '../components/Testimonial.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
---

<BaseLayout
  title="Start"
  description="Evoque – Yourself: Coaching für Menschen, die feststecken. Erreiche dein Ziel trotz Hürden – mit einer Begleiterin als Anker."
>
  <Hero
    eyebrow="Coaching & Strategy"
    title="Komm ins Handeln – auch wenn du feststeckst."
    text="Evoque begleitet Menschen, die ein Ziel haben, aber immer wieder an der gleichen Hürde scheitern – ob Prüfungsangst, Prokrastination oder ein langjähriges Thema. Gemeinsam verstehen wir, woher es kommt, und verändern es im Hier und Jetzt."
    image="/images/Instagram/become_your_best_you.png"
    imageAlt="Become your best you – Evoque Coaching"
    ctaHref="/kontakt#buchung"
    ctaLabel="Kennenlerngespräch buchen"
    secondaryHref="/coaching"
    secondaryLabel="So läuft das Coaching"
  />

  <!-- Ansatz-Teaser -->
  <section class="section surface-sand">
    <div class="container">
      <div class="approach">
        <div class="approach__intro">
          <SectionHeading
            eyebrow="Der Ansatz"
            title="Woher kommt das Problem?"
          >
            <p>
              Veränderung beginnt mit Verstehen. Wir schauen gemeinsam auf den
              Ursprung – und gestalten Schritt für Schritt einen neuen Weg.
            </p>
          </SectionHeading>
          <a href="/ueber-mich" class="btn btn--primary">Mehr über den Ansatz</a>
        </div>
        <ol class="approach__steps">
          <li>
            <span class="approach__step-num">1</span>
            <div>
              <h3>Vergangenheit verstehen</h3>
              <p class="text-muted">Woher kommt das Thema? Wir finden den Ursprung.</p>
            </div>
          </li>
          <li>
            <span class="approach__step-num">2</span>
            <div>
              <h3>Im Hier und Jetzt verändern</h3>
              <p class="text-muted">Aus dem Verstehen wird konkrete Veränderung.</p>
            </div>
          </li>
          <li>
            <span class="approach__step-num">3</span>
            <div>
              <h3>Anker & Begleiterin</h3>
              <p class="text-muted">
                Ich bleibe an deiner Seite, bis du dein Ziel erreichst.
              </p>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <!-- Themen-Teaser -->
  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Themen & Anliegen"
        title="Wobei Evoque dich begleitet"
        align="center"
      >
        <p>Typische Anliegen – und Raum für dein ganz persönliches Thema.</p>
      </SectionHeading>

      <div class="grid grid--3">
        <TopicCard title="Prüfungsangst">
          Wieder ruhig und klar in Prüfungssituationen gehen.
        </TopicCard>
        <TopicCard title="Prokrastination">
          Ins Tun kommen, statt Aufgaben immer weiter aufzuschieben.
        </TopicCard>
        <TopicCard title="Langjährige Themen">
          Themen wie Abnehmen, die dich schon lange begleiten, nachhaltig angehen.
        </TopicCard>
      </div>

      <p class="center themes-teaser__more">
        <a href="/coaching" class="btn btn--primary">Alle Themen & Pakete ansehen</a>
      </p>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section surface-sand">
    <div class="container">
      <SectionHeading
        eyebrow="Stimmen"
        title="Was Begleitete erleben"
        align="center"
      />
      <div class="grid grid--3">
        <Testimonial
          quote="[PLATZHALTER: Testimonial 1 – authentische Stimme einer begleiteten Person.]"
          author="[PLATZHALTER: Name / Anliegen]"
        />
        <Testimonial
          quote="[PLATZHALTER: Testimonial 2 – authentische Stimme einer begleiteten Person.]"
          author="[PLATZHALTER: Name / Anliegen]"
        />
        <Testimonial
          quote="[PLATZHALTER: Testimonial 3 – authentische Stimme einer begleiteten Person.]"
          author="[PLATZHALTER: Name / Anliegen]"
        />
      </div>
    </div>
  </section>

  <!-- Abschluss-CTA -->
  <section class="section">
    <div class="container">
      <div class="final-cta surface-forest">
        <div class="final-cta__text">
          <p class="eyebrow">Bereit für den ersten Schritt?</p>
          <h2>Lerne mich in einem kostenlosen Gespräch kennen.</h2>
          <p>
            30 Minuten, unverbindlich – wir schauen, ob es passt und wie ich dich
            begleiten kann.
          </p>
        </div>
        <a href="/kontakt#buchung" class="btn btn--secondary">Kennenlerngespräch buchen</a>
      </div>

      <div class="final-cta__disclaimer">
        <DisclaimerBanner />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .approach {
    display: grid;
    gap: var(--space-2xl);
    align-items: start;
  }
  @media (min-width: 860px) {
    .approach {
      grid-template-columns: 1fr 1fr;
    }
  }
  .approach__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-lg);
  }
  .approach__steps li {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: var(--space-md);
    align-items: start;
  }
  .approach__steps h3 {
    margin-bottom: var(--space-2xs);
  }
  .approach__steps p {
    margin: 0;
  }
  .approach__step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 999px;
    background: var(--sage-harmony);
    color: var(--forest-deep);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.2rem;
  }

  .themes-teaser__more {
    margin-top: var(--space-xl);
  }

  .final-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xl);
    align-items: center;
    justify-content: space-between;
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
  }
  .final-cta__text {
    max-width: 52ch;
  }
  .final-cta__text h2 {
    margin-bottom: var(--space-sm);
  }
  .final-cta__text p:last-child {
    margin-bottom: 0;
  }
  .final-cta__disclaimer {
    margin-top: var(--space-xl);
  }
</style>
