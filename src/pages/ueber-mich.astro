---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FlowerCorner from '../components/FlowerCorner.astro';
---

<BaseLayout
  title="Über mich"
  description="Lerne Malin kennen – Coach & Strategieberaterin bei Evoque. Der Ansatz: Problemursprung verstehen und im Hier und Jetzt verändern."
>
  <!-- Vorstellung -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Über mich</p>
      <div class="intro">
        <div class="intro__media">
          <span class="intro-flower intro-flower--tl" aria-hidden="true">
            <FlowerCorner />
          </span>
          <img
            src="/images/About_Me_Malin_Images/DSC00751.jpg"
            alt="Porträt von Malin, Coach bei Evoque"
            width="560"
            height="700"
          />
          <span class="intro-flower intro-flower--br" aria-hidden="true">
            <FlowerCorner />
          </span>
        </div>
        <div class="intro__text">
          <h1>Schön, dass Sie da bist.</h1>
          <p class="lead">
            [PLATZHALTER: Bio-Text – persönliche Vorstellung von Malin: Wer sie ist,
            ihr Werdegang, ihre Haltung und warum sie Menschen als Coach begleitet.]
          </p>
          <p class="text-muted">
            [PLATZHALTER: Bio-Text – weiterer Absatz: Qualifikation, Erfahrung und was
            ihr in der Begleitung wichtig ist.]
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Der Ansatz -->
  <section class="section surface-sand">
    <div class="container">
      <SectionHeading
        eyebrow="Der Ansatz"
        title="Verstehen, woher es kommt – verändern, wo du heute stehst."
      >
        <p>
          Mein Weg führt vom Ursprung des Problems zur Veränderung im Hier und Jetzt.
        </p>
      </SectionHeading>

      <div class="grid grid--3 approach-cards">
        <article class="card">
          <h3>1 · Problemursprung</h3>
          <p class="text-muted">
            Wir klären, worum es wirklich geht: was, wann, wo, wie lange – und warum.
          </p>
        </article>
        <article class="card">
          <h3>2 · Vergangenheit verstehen</h3>
          <p class="text-muted">
            Wir schauen auf die Wurzeln des Themas, ohne dort stehen zu bleiben.
          </p>
        </article>
        <article class="card">
          <h3>3 · Im Hier und Jetzt verändern</h3>
          <p class="text-muted">
            Aus Verstehen wird Handeln – Schritt für Schritt, in deinem Tempo.
          </p>
        </article>
      </div>

      <div class="anchor">
        <div class="anchor__images">
          <img
            src="/images/About_Me_Malin_Images/DSC00842.jpg"
            alt="Malin – Porträt im Querformat"
            width="780"
            height="488"
          />
        </div>
        <div class="anchor__text">
          <h2>Ich bin dein Anker und deine Begleiterin.</h2>
          <p>
            Du musst den Weg nicht allein gehen. Ich bleibe an deiner Seite, halte den
            Kurs mit dir und sorge dafür, dass du dranbleibst – bis du dein Ziel
            erreichst.
          </p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .intro {
    display: grid;
    gap: var(--space-2xl);
    align-items: center;
    /* etwas Luft, damit die obere Eckblume nicht an den "Über mich"-Text stößt */
    margin-top: var(--space-lg);
  }
  @media (min-width: 860px) {
    .intro {
      grid-template-columns: 0.85fr 1.15fr;
    }
  }
  .intro__media {
    position: relative;
  }
  .intro__media img {
    display: block;
    width: 100%;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    object-fit: cover;
    aspect-ratio: 4 / 5;
  }

  /* Floraler Eckschmuck als Blumenrahmen */
  .intro-flower {
    position: absolute;
    width: clamp(84px, 32%, 150px);
    z-index: 2;
    pointer-events: none;
  }
  .intro-flower--tl {
    top: -20px;
    left: -20px;
  }
  .intro-flower--br {
    right: -20px;
    bottom: -20px;
    transform: rotate(180deg);
  }

  .approach-cards {
    margin-bottom: var(--space-2xl);
  }
  .approach-cards .card h3 {
    margin-bottom: var(--space-xs);
  }
  .approach-cards .card p {
    margin: 0;
  }

  .anchor {
    display: grid;
    gap: var(--space-2xl);
    align-items: center;
  }
  @media (min-width: 860px) {
    .anchor {
      grid-template-columns: 1fr 1fr;
    }
  }
  .anchor__images {
    /* ===== HIER EINSTELLEN ===== */
    --img-zoom: 1; /* Zoom: 1 = Grundeinstellung, größer = näher ran (z. B. 1.2) */
    --img-x: 50%; /* Links/Rechts: 0% = ganz links, 50% = Mitte, 100% = ganz rechts */
    --img-y: 45%; /* Hoch/Runter: 0% = ganz oben, 50% = Mitte, 100% = ganz unten */
    --img-ratio: 3.7 / 3; /* Bildausschnitt (Breite/Höhe): kleiner = höher/mehr drauf, z. B. 5 / 4 */
    /* =========================== */

    aspect-ratio: var(--img-ratio);
    overflow: hidden;
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
  }
  .anchor__images img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--img-x) var(--img-y);
    transform: scale(var(--img-zoom));
    transform-origin: var(--img-x) var(--img-y);
  }
  .anchor__text p {
    margin-bottom: 0;
  }
</style>
