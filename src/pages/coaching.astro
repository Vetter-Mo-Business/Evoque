---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TopicCard from '../components/TopicCard.astro';
import ProcessJourney from '../components/ProcessJourney.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
---

<BaseLayout
  title="Coaching"
  description="Themen, Ablauf und Paketoptionen des Evoque-Coachings: von Prüfungsangst über Prokrastination bis zu langjährigen Themen."
>
  <!-- Intro -->
  <section class="section section--tight">
    <div class="container container--narrow center">
      <p class="eyebrow">Coaching</p>
      <h1>Eine Begleitung, die zu deinem Thema passt.</h1>
      <p class="lead">
        Kein Verkauf einzelner Sitzungen, sondern eine echte Begleitung – so lange,
        wie dein Thema es braucht.
      </p>
    </div>
  </section>

  <!-- Themen / Anliegen -->
  <section class="section surface-sand">
    <div class="container">
      <SectionHeading
        eyebrow="Themen & Anliegen"
        title="Womit Menschen zu mir kommen"
      >
        <p>Häufige Anliegen – und Raum für dein persönliches Thema.</p>
      </SectionHeading>

      <div
        class="topic-slider"
        data-topic-slider
        role="group"
        aria-roledescription="Karussell"
        aria-label="Themen, mit denen Menschen kommen"
      >
        <div class="topic-slider__viewport" data-viewport>
          <div class="topic-slider__track" data-track>
            <div class="topic-slider__slide">
              <TopicCard title="Prüfungsangst">
                Wieder ruhig, klar und handlungsfähig in Prüfungssituationen.
              </TopicCard>
            </div>
            <div class="topic-slider__slide">
              <TopicCard title="Prokrastination">
                Aufschieben durchbrechen und verlässlich ins Tun kommen.
              </TopicCard>
            </div>
            <div class="topic-slider__slide">
              <TopicCard title="Langjährige Themen (z. B. Abnehmen)">
                Themen, die dich seit Jahren begleiten, an der Wurzel angehen.
              </TopicCard>
            </div>
            <div class="topic-slider__slide">
              <TopicCard title="Selbstzweifel & Selbstwert">
                Wieder Vertrauen in dich und deine Fähigkeiten aufbauen.
              </TopicCard>
            </div>
            <div class="topic-slider__slide">
              <TopicCard title="Stress & innere Unruhe">
                Zur Ruhe kommen und gelassener mit Druck und Anspannung umgehen.
              </TopicCard>
            </div>
            <div class="topic-slider__slide">
              <TopicCard title="Klarheit & Entscheidungen">
                Den eigenen Weg finden und Entscheidungen wieder sicher treffen.
              </TopicCard>
            </div>
            <div class="topic-slider__slide">
              <TopicCard title="Dein Thema" placeholder>
                [PLATZHALTER: weitere Themen – hier weitere Anliegen ergänzen, mit
                denen Malin arbeitet.]
              </TopicCard>
            </div>
          </div>
        </div>

        <div class="topic-slider__controls">
          <button
            type="button"
            class="topic-slider__nav"
            data-prev
            aria-label="Vorheriges Thema"
          >
            ‹
          </button>
          <div class="topic-slider__dots" data-dots aria-hidden="true"></div>
          <button
            type="button"
            class="topic-slider__nav"
            data-next
            aria-label="Nächstes Thema"
          >
            ›
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Ablauf-Prozess: gepinnte Scroll-Animation -->
  <ProcessJourney />

  <!-- USP: Der Unterschied zur üblichen Herangehensweise -->
  <section class="section surface-sand">
    <div class="container">
      <SectionHeading
        eyebrow="Der Unterschied"
        title="Warum echte Begleitung mehr bewirkt"
        align="center"
      >
        <p>
          Viele setzen auf einzelne Sitzungen und schnelle Tipps. Ich begleite dich
          anders – so lange, bis dein Ziel wirklich erreicht ist.
        </p>
      </SectionHeading>
      <div class="grid grid--2 offer-grid">
        <article class="card offer-card offer-card--others">
          <span class="offer-card__tag offer-card__tag--muted">Der übliche Weg</span>
          <h3>Wie es oft läuft</h3>
          <p class="text-muted">
            Schnelle Tipps in einer überfüllten Gruppendynamik. <br> Und danach stehst du wieder allein
            mit deinem Thema da. Oberfläche statt Ursache.
          </p>
          <ul class="offer-list offer-list--cons">
            <li>Persönliche Probleme in offener Runde</li>
            <li>Schnelle Tipps statt echter Ursachenarbeit</li>
            <li>Nach der Sitzung auf dich allein gestellt</li>
            <li>Das alte Thema kommt immer wieder zurück</li>
          </ul>
        </article>
        <article class="card offer-card offer-card--highlight">
          <span class="offer-card__tag">So begleite ich dich</span>
          <h3>Persönliche Begleitung bei Evoque</h3>
          <p>
            Eine echte Begleitung, ganz auf dich zugeschnitten. <br> Ich begleite dich persönlich, bis du dein Ziel erreicht hast. An der Wurzel, nicht an der Oberfläche.
          </p>
          <ul class="offer-list">
            <li>Durchgehende Begleitung bis zum Ziel</li>
            <li>An der Ursache arbeiten – nachhaltig</li>
            <li>Individuell auf dich abgestimmt</li>
            <li>Dein verlässlicher Anker auf dem ganzen Weg</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- Abgrenzung Coaching vs. Therapie -->
  <section class="section">
    <div class="container container--narrow">
      <SectionHeading
        eyebrow="Wichtig zu wissen"
        title="Coaching – keine Therapie."
        align="center"
      >
        <p>
          Ich begleite dich bei Problemen und Sorgen rund um deine
          Persönlichkeitsentwicklung. Geht es um therapeutische Anliegen, ist eine
          Psychotherapie oder Heilbehandlung der richtige Weg – das ersetzt mein
          Coaching ausdrücklich nicht.
        </p>
      </SectionHeading>
      <DisclaimerBanner variant="strong" />
    </div>
  </section>
</BaseLayout>

<style>
  .offer-grid {
    margin-top: var(--space-md);
  }

  /* ===== Themen-Slider ===== */
  .topic-slider {
    margin-top: var(--space-md);
  }
  .topic-slider__viewport {
    position: relative;
    overflow: hidden;
  }
  /* Fade rechts: deutet an, dass noch eine weitere Karte folgt */
  .topic-slider__viewport::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 14%;
    max-width: 120px;
    background: linear-gradient(
      to right,
      rgba(225, 210, 203, 0),
      var(--soft-sand)
    );
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.35s ease;
    z-index: 2;
  }
  .topic-slider.is-end .topic-slider__viewport::after {
    opacity: 0;
  }
  .topic-slider__track {
    display: flex;
    gap: var(--space-lg);
    align-items: stretch;
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }
  /* Mobil: 1 Karte + Andeutung der nächsten */
  .topic-slider__slide {
    flex: 0 0 82%;
    min-width: 0;
  }
  /* Tablet: 2 Karten + Andeutung */
  @media (min-width: 560px) {
    .topic-slider__slide {
      flex-basis: 46%;
    }
  }
  /* Desktop: 3 Karten + die vierte rechts angedeutet */
  @media (min-width: 900px) {
    .topic-slider__slide {
      flex-basis: 30%;
    }
  }

  .topic-slider__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }
  .topic-slider__nav {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    flex-shrink: 0;
    border: none;
    border-radius: 999px;
    background: var(--forest-deep);
    color: var(--on-dark);
    font-size: 1.6rem;
    line-height: 1;
    padding-bottom: 0.12em;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.15s ease,
      opacity 0.2s ease;
  }
  .topic-slider__nav:hover {
    background: #0e2113;
    transform: translateY(-2px);
  }
  .topic-slider__dots {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }
  .topic-slider__dot {
    width: 9px;
    height: 9px;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: rgba(21, 44, 26, 0.22);
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  .topic-slider__dot:hover {
    background: rgba(21, 44, 26, 0.4);
  }
  .topic-slider__dot[aria-current='true'] {
    background: var(--forest-deep);
    transform: scale(1.25);
  }

  .offer-card {
    height: 100%;
  }
  .offer-card h3 {
    margin-bottom: var(--space-sm);
  }

  /* Kleines Label oben auf den Karten */
  .offer-card__tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--forest-deep);
    background: var(--bg);
    border-radius: 999px;
    padding: 0.4em 0.9em;
    margin-bottom: var(--space-sm);
  }
  .offer-card__tag--muted {
    background: transparent;
    color: var(--calm-earth);
    border: var(--border-soft);
  }

  /* "Üblicher Weg": bewusst zurückgenommen, damit das eigene Angebot heraussticht */
  .offer-card--others {
    background: var(--bg);
    border: var(--border-soft);
    box-shadow: none;
  }
  .offer-card--others h3 {
    color: var(--calm-earth);
  }

  /* Eigenes Angebot: klar hervorgehoben */
  .offer-card--highlight {
    background: var(--sage-harmony);
    border: 1px solid rgba(21, 44, 26, 0.25);
    box-shadow: var(--shadow-card);
  }

  .offer-list {
    list-style: none;
    margin: var(--space-md) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-xs);
  }
  .offer-list li {
    padding-left: 1.4em;
    position: relative;
  }
  .offer-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    font-weight: 700;
    color: var(--forest-deep);
  }
  /* Negativliste für den "üblichen Weg": ✕ statt ✓, gedämpft */
  .offer-list--cons li {
    color: var(--calm-earth);
  }
  .offer-list--cons li::before {
    content: '✕';
    color: var(--calm-earth);
  }

</style>

<script>
  // Themen-Slider: läuft automatisch von links nach rechts,
  // kann aber per Pfeilen, Punkten und Wischgeste auch manuell bedient werden.
  const slider = document.querySelector<HTMLElement>('[data-topic-slider]');
  if (slider) {
    const viewport = slider.querySelector<HTMLElement>('[data-viewport]')!;
    const track = slider.querySelector<HTMLElement>('[data-track]')!;
    const slides = Array.from(track.children) as HTMLElement[];
    const prevBtn = slider.querySelector<HTMLButtonElement>('[data-prev]')!;
    const nextBtn = slider.querySelector<HTMLButtonElement>('[data-next]')!;
    const dotsWrap = slider.querySelector<HTMLElement>('[data-dots]')!;

    const reduceMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;
    const AUTOPLAY_MS = 2800; // Auto-Lauf: startet früher / etwas zügiger
    const RESUME_MS = 10000; // nach eigener Bedienung 10 s warten

    let index = 0;
    let timer: ReturnType<typeof setInterval> | undefined;
    let resumeTimer: ReturnType<typeof setTimeout> | undefined;

    // Punkte aufbauen (einer pro Slide)
    const dots = slides.map((_, i) => {
      const dot = document.createElement('button');
      dot.type = 'button';
      dot.className = 'topic-slider__dot';
      dot.setAttribute('aria-label', `Thema ${i + 1} anzeigen`);
      dot.addEventListener('click', () => {
        goTo(i);
        scheduleResume();
      });
      dotsWrap.appendChild(dot);
      return dot;
    });

    function maxOffset() {
      return Math.max(0, track.scrollWidth - viewport.clientWidth);
    }

    // Größter Index, der noch sinnvoll anfahrbar ist (letzte Karte sichtbar)
    function lastIndex() {
      const max = maxOffset();
      for (let i = 0; i < slides.length; i++) {
        if (slides[i].offsetLeft >= max - 1) return i;
      }
      return slides.length - 1;
    }

    function goTo(i: number) {
      const last = lastIndex();
      if (i > last) i = 0; // am Ende wieder an den Anfang
      if (i < 0) i = last;
      index = i;
      const max = maxOffset();
      const x = Math.min(slides[i].offsetLeft, max);
      track.style.transform = `translateX(${-x}px)`;
      dots.forEach((d, di) =>
        d.setAttribute('aria-current', di === index ? 'true' : 'false')
      );
      // Fade ausblenden, sobald die letzte Karte voll sichtbar ist
      slider!.classList.toggle('is-end', x >= max - 1);
    }

    function next() {
      goTo(index + 1);
    }
    function prev() {
      goTo(index - 1);
    }

    function play() {
      if (resumeTimer) {
        clearTimeout(resumeTimer);
        resumeTimer = undefined;
      }
      if (reduceMotion || timer) return;
      timer = setInterval(next, AUTOPLAY_MS);
    }
    function stop() {
      if (timer) {
        clearInterval(timer);
        timer = undefined;
      }
    }
    // Nach eigener Bedienung erst nach RESUME_MS wieder automatisch laufen
    function scheduleResume() {
      stop();
      if (resumeTimer) clearTimeout(resumeTimer);
      if (reduceMotion) return;
      resumeTimer = setTimeout(play, RESUME_MS);
    }

    nextBtn.addEventListener('click', () => {
      next();
      scheduleResume();
    });
    prevBtn.addEventListener('click', () => {
      prev();
      scheduleResume();
    });

    // Pause bei Hover / Fokus; danach erst nach kurzer Wartezeit weiter
    slider.addEventListener('mouseenter', stop);
    slider.addEventListener('mouseleave', scheduleResume);
    slider.addEventListener('focusin', stop);
    slider.addEventListener('focusout', scheduleResume);

    // Wischgeste (Touch)
    let startX = 0;
    let dragging = false;
    viewport.addEventListener(
      'touchstart',
      (e) => {
        startX = e.touches[0].clientX;
        dragging = true;
        stop();
      },
      { passive: true }
    );
    viewport.addEventListener(
      'touchend',
      (e) => {
        if (!dragging) return;
        dragging = false;
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) > 40) {
          dx < 0 ? next() : prev();
        }
        scheduleResume();
      },
      { passive: true }
    );

    // Bei Resize Position neu berechnen
    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => goTo(index), 150);
    });

    goTo(0);
    play();
  }
</script>
