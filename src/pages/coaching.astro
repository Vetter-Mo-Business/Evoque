---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TopicCard from '../components/TopicCard.astro';
import ProcessJourney from '../components/ProcessJourney.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import { localizePath, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? 'de') as Lang;
const l = (p: string) => localizePath(p, lang);

const content = {
  de: {
    metaTitle: 'Coaching',
    metaDesc:
      'Themen, Ablauf und Paketoptionen des Evoque-Coachings: von Prüfungsangst über Prokrastination bis zu langjährigen Themen.',
    introEyebrow: 'Coaching',
    introTitle: 'Eine Begleitung, die zu deinem Thema passt.',
    introLead:
      'Kein Verkauf einzelner Sitzungen, sondern eine echte Begleitung – so lange, wie dein Thema es braucht.',
    topicsEyebrow: 'Themen & Anliegen',
    topicsTitle: 'Womit Menschen zu mir kommen',
    topicsLead: 'Häufige Anliegen – und Raum für dein persönliches Thema.',
    carouselLabel: 'Themen, mit denen Menschen kommen',
    prev: 'Vorheriges Thema',
    next: 'Nächstes Thema',
    topics: [
      { title: 'Selbstorganisation', items: ['Prokrastination', 'Multitasking', 'Aufschieben', 'Zeitdruck'] },
      { title: 'Stress & innere Ruhe', items: ['Prüfungsangst', 'Anspannung', 'Überforderung', 'Innere Unruhe'] },
      { title: 'Selbstwert & Vertrauen', items: ['Selbstzweifel', 'Unsicherheit', 'Innerer Kritiker'] },
      { title: 'Klarheit & Entscheidungen', items: ['Orientierung', 'Entscheidungen treffen', 'Eigener Weg'] },
      { title: 'Langjährige Themen', items: ['Abnehmen', 'Gewohnheiten', 'Wiederkehrende Muster'] },
    ],
    placeholderTitle: 'Dein Thema',
    placeholderItems: ['[Oberthema ergänzen]', '[Unterthema]', '[Unterthema]'],
    uspEyebrow: 'Der Unterschied',
    uspTitle: 'Warum echte Begleitung mehr bewirkt',
    uspLead:
      'Ob Gruppe oder lose Einzelsitzungen anderswo – vieles bleibt an der Oberfläche. Ich begleite dich psychologisch fundiert so lange, bis dein Ziel wirklich erreicht ist.',
    groupTag: 'Gruppen-Coaching',
    groupTitle: 'Tipps in der Gruppe',
    groupText:
      'Schnelle Tipps in einer überfüllten Gruppendynamik. Danach stehst du wieder allein mit deinem Thema da – Oberfläche statt Ursache.',
    groupCons: [
      'Persönliche Probleme in offener Runde',
      'Schnelle Tipps statt echter Ursachenarbeit',
      'Kaum individueller Bezug',
      'Nach der Sitzung auf dich allein gestellt',
    ],
    evoqueTag: 'Coaching bei Evoque',
    evoqueTitle: 'Begleitung mit Fundament',
    evoqueText:
      'Eine echte Begleitung, ganz auf dich zugeschnitten – psychologisch fundiert, weil ich es studiert habe. Ich bleibe an deiner Seite, bis du dein Ziel erreicht hast. An der Wurzel, nicht an der Oberfläche.',
    evoquePros: [
      'Psychologisch fundiert – studierter Hintergrund',
      'Durchgehende Begleitung bis zum Ziel',
      'An der Ursache arbeiten – nachhaltig',
      'Dein verlässlicher Anker auf dem ganzen Weg',
    ],
    soloTag: 'Persönliches Coaching',
    soloTitle: 'Einzelne Sitzungen',
    soloText:
      'Persönlicher als die Gruppe – aber oft lose Einzelsitzungen ohne roten Faden und ohne fundierten Hintergrund. Das alte Thema kehrt zurück.',
    soloCons: [
      'Einzelne Sitzungen statt durchgehender Begleitung',
      'Selten psychologisch fundiert',
      'Kein verlässlicher Anker danach',
      'Das Thema kommt mit der Zeit zurück',
    ],
    expA: 'Was auf dich zukommt',
    expAText:
      'Ich bringe die Begleitung mit: einen klaren, fundierten Weg – und ich bleibe an deiner Seite, bis dein Ziel erreicht ist. Ich höre zu, frage nach, gebe Struktur und sorge dafür, dass du dranbleibst.',
    expB: 'Was du mitbringst',
    expBText:
      'Was ich dir nicht abnehmen kann, ist die Motivation, dein Ziel wirklich zu erreichen. Sie entsteht in dir und lässt sich nicht von außen geben. Veränderung gelingt, wenn beides zusammenkommt: meine Begleitung und dein eigener Wille.',
    therapyEyebrow: 'Wichtig zu wissen',
    therapyTitle: 'Coaching – keine Therapie.',
    therapyText:
      'Ich begleite dich bei Problemen und Sorgen rund um deine Persönlichkeitsentwicklung. Geht es um therapeutische Anliegen, ist eine Psychotherapie oder Heilbehandlung der richtige Weg – das ersetzt mein Coaching ausdrücklich nicht.',
  },
  en: {
    metaTitle: 'Coaching',
    metaDesc:
      'Topics, process and package options of Evoque coaching: from exam anxiety and procrastination to long-standing issues.',
    introEyebrow: 'Coaching',
    introTitle: 'Guidance that fits your topic.',
    introLead:
      'Not single sessions for sale, but real guidance – for as long as your topic needs.',
    topicsEyebrow: 'Topics & concerns',
    topicsTitle: 'What people come to me with',
    topicsLead: 'Common concerns – and room for your personal topic.',
    carouselLabel: 'Topics people come with',
    prev: 'Previous topic',
    next: 'Next topic',
    topics: [
      { title: 'Self-organisation', items: ['Procrastination', 'Multitasking', 'Putting things off', 'Time pressure'] },
      { title: 'Stress & inner calm', items: ['Exam anxiety', 'Tension', 'Overwhelm', 'Inner restlessness'] },
      { title: 'Self-worth & confidence', items: ['Self-doubt', 'Insecurity', 'Inner critic'] },
      { title: 'Clarity & decisions', items: ['Orientation', 'Making decisions', 'Your own path'] },
      { title: 'Long-standing issues', items: ['Weight loss', 'Habits', 'Recurring patterns'] },
    ],
    placeholderTitle: 'Your topic',
    placeholderItems: ['[Add main topic]', '[Sub-topic]', '[Sub-topic]'],
    uspEyebrow: 'The difference',
    uspTitle: 'Why real guidance achieves more',
    uspLead:
      'Whether a group or loose individual sessions elsewhere – much stays on the surface. I support you on a psychologically grounded basis, until your goal is truly reached.',
    groupTag: 'Group coaching',
    groupTitle: 'Tips in a group',
    groupText:
      'Quick tips in a crowded group dynamic. Afterwards you are left alone with your topic again – surface instead of cause.',
    groupCons: [
      'Personal issues in an open round',
      'Quick tips instead of real root-cause work',
      'Hardly any individual focus',
      'Left on your own after the session',
    ],
    evoqueTag: 'Coaching at Evoque',
    evoqueTitle: 'Guidance with a foundation',
    evoqueText:
      'Real guidance, tailored entirely to you – psychologically grounded, because I studied it. I stay by your side until you have reached your goal. At the root, not on the surface.',
    evoquePros: [
      'Psychologically grounded – studied background',
      'Continuous guidance until the goal',
      'Working at the cause – sustainably',
      'Your reliable anchor all the way',
    ],
    soloTag: 'Individual coaching',
    soloTitle: 'Single sessions',
    soloText:
      'More personal than the group – but often loose single sessions without a common thread or grounded background. The old topic returns.',
    soloCons: [
      'Single sessions instead of continuous guidance',
      'Rarely psychologically grounded',
      'No reliable anchor afterwards',
      'The topic comes back over time',
    ],
    expA: 'What to expect',
    expAText:
      'I bring the guidance: a clear, grounded path – and I stay by your side until your goal is reached. I listen, ask, give structure and make sure you stay on track.',
    expB: 'What you bring',
    expBText:
      'What I cannot take off your shoulders is the motivation to truly reach your goal. It arises within you and cannot be given from outside. Change succeeds when both come together: my guidance and your own will.',
    therapyEyebrow: 'Good to know',
    therapyTitle: 'Coaching – not therapy.',
    therapyText:
      'I support you with problems and worries around your personal development. For therapeutic concerns, psychotherapy or medical treatment is the right path – my coaching explicitly does not replace it.',
  },
}[lang];
---

<BaseLayout title={content.metaTitle} description={content.metaDesc}>
  <!-- Intro -->
  <section class="section section--tight">
    <div class="container container--narrow center">
      <p class="eyebrow">{content.introEyebrow}</p>
      <h1>{content.introTitle}</h1>
      <p class="lead">{content.introLead}</p>
    </div>
  </section>

  <!-- Themen / Anliegen -->
  <section class="section surface-sand">
    <div class="container">
      <SectionHeading
        eyebrow={content.topicsEyebrow}
        title={content.topicsTitle}
      >
        <p>{content.topicsLead}</p>
      </SectionHeading>

      <div
        class="topic-slider"
        data-topic-slider
        role="group"
        aria-roledescription="Karussell"
        aria-label={content.carouselLabel}
      >
        <div class="topic-slider__viewport" data-viewport>
          <div class="topic-slider__track" data-track>
            {
              content.topics.map((topic) => (
                <div class="topic-slider__slide">
                  <TopicCard title={topic.title} items={topic.items} />
                </div>
              ))
            }
            <div class="topic-slider__slide">
              <TopicCard
                title={content.placeholderTitle}
                placeholder
                items={content.placeholderItems}
              />
            </div>
          </div>
        </div>

        <div class="topic-slider__controls">
          <button
            type="button"
            class="topic-slider__nav"
            data-prev
            aria-label={content.prev}
          >
            ‹
          </button>
          <div class="topic-slider__dots" data-dots aria-hidden="true"></div>
          <button
            type="button"
            class="topic-slider__nav"
            data-next
            aria-label={content.next}
          >
            ›
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Ablauf-Prozess: gepinnte Scroll-Animation -->
  <ProcessJourney />

  <!-- USP: Der Unterschied zur üblichen Herangehensweise -->
  <section class="section surface-sand">
    <div class="container">
      <SectionHeading
        eyebrow={content.uspEyebrow}
        title={content.uspTitle}
        align="center"
      >
        <p>{content.uspLead}</p>
      </SectionHeading>
      <div class="grid grid--3 offer-grid">
        <article class="card offer-card offer-card--others">
          <span class="offer-card__tag offer-card__tag--muted">{content.groupTag}</span>
          <h3>{content.groupTitle}</h3>
          <p class="text-muted">{content.groupText}</p>
          <ul class="offer-list offer-list--cons">
            {content.groupCons.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="card offer-card offer-card--highlight">
          <span class="offer-card__tag">{content.evoqueTag}</span>
          <h3>{content.evoqueTitle}</h3>
          <p>{content.evoqueText}</p>
          <ul class="offer-list">
            {content.evoquePros.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="card offer-card offer-card--others">
          <span class="offer-card__tag offer-card__tag--muted">{content.soloTag}</span>
          <h3>{content.soloTitle}</h3>
          <p class="text-muted">{content.soloText}</p>
          <ul class="offer-list offer-list--cons">
            {content.soloCons.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>

      <!-- Begleitung vs. Eigenverantwortung: zwei aufklappbare Boxen nebeneinander -->
      <div class="expectations">
        <details class="expectation">
          <summary class="expectation__summary">{content.expA}</summary>
          <div class="expectation__body">
            <p>{content.expAText}</p>
          </div>
        </details>
        <details class="expectation">
          <summary class="expectation__summary">{content.expB}</summary>
          <div class="expectation__body">
            <p>{content.expBText}</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- Abgrenzung Coaching vs. Therapie -->
  <section class="section">
    <div class="container container--narrow">
      <SectionHeading
        eyebrow={content.therapyEyebrow}
        title={content.therapyTitle}
        align="center"
      >
        <p>{content.therapyText}</p>
      </SectionHeading>
      <DisclaimerBanner variant="strong" />
    </div>
  </section>
</BaseLayout>

<style>
  .offer-grid {
    margin-top: calc(var(--space-md) + 50px);
  }

  /* Zwei aufklappbare Boxen nebeneinander: Begleitung vs. Eigenverantwortung */
  .expectations {
    margin-top: var(--space-2xl);
    display: grid;
    gap: var(--space-lg);
  }
  @media (min-width: 720px) {
    .expectations {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  /* Aufklapp-Box (auch für FAQ genutzt) */
  .expectation {
    background: #fff;
    border: var(--border-soft);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
  }
  .expectation__summary {
    cursor: pointer;
    list-style: none;
    padding: var(--space-md) var(--space-lg);
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--forest-deep);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }
  .expectation__summary::-webkit-details-marker {
    display: none;
  }
  .expectation__summary::after {
    content: '+';
    font-size: 1.5rem;
    line-height: 1;
    color: var(--calm-earth);
    flex-shrink: 0;
  }
  .expectation[open] .expectation__summary::after {
    content: '–';
  }
  .expectation__body {
    padding: 0 var(--space-lg) var(--space-lg);
  }
  .expectation__body p {
    margin: 0;
    color: var(--calm-earth);
    line-height: 1.6;
  }

  /* ===== Themen-Slider ===== */
  .topic-slider {
    margin-top: var(--space-md);
  }
  .topic-slider__viewport {
    position: relative;
    overflow: hidden;
  }
  /* Fade rechts: deutet an, dass noch eine weitere Karte folgt */
  .topic-slider__viewport::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 14%;
    max-width: 120px;
    background: linear-gradient(
      to right,
      rgba(225, 210, 203, 0),
      var(--soft-sand)
    );
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.35s ease;
    z-index: 2;
  }
  .topic-slider.is-end .topic-slider__viewport::after {
    opacity: 0;
  }
  .topic-slider__track {
    display: flex;
    gap: var(--space-lg);
    align-items: stretch;
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }
  /* Mobil: 1 Karte + Andeutung der nächsten */
  .topic-slider__slide {
    flex: 0 0 82%;
    min-width: 0;
  }
  /* Tablet: 2 Karten + Andeutung */
  @media (min-width: 560px) {
    .topic-slider__slide {
      flex-basis: 46%;
    }
  }
  /* Desktop: 3 Karten + die vierte rechts angedeutet */
  @media (min-width: 900px) {
    .topic-slider__slide {
      flex-basis: 30%;
    }
  }

  .topic-slider__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }
  .topic-slider__nav {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    flex-shrink: 0;
    border: none;
    border-radius: 999px;
    background: var(--forest-deep);
    color: var(--on-dark);
    font-size: 1.6rem;
    line-height: 1;
    padding-bottom: 0.12em;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.15s ease,
      opacity 0.2s ease;
  }
  .topic-slider__nav:hover {
    background: #0e2113;
    transform: translateY(-2px);
  }
  .topic-slider__dots {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }
  .topic-slider__dot {
    width: 9px;
    height: 9px;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: rgba(21, 44, 26, 0.22);
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  .topic-slider__dot:hover {
    background: rgba(21, 44, 26, 0.4);
  }
  .topic-slider__dot[aria-current='true'] {
    background: var(--forest-deep);
    transform: scale(1.25);
  }

  .offer-card {
    height: 100%;
  }
  .offer-card h3 {
    margin-bottom: var(--space-sm);
  }

  /* Kleines Label oben auf den Karten */
  .offer-card__tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--forest-deep);
    background: var(--bg);
    border-radius: 999px;
    padding: 0.4em 0.9em;
    margin-bottom: var(--space-sm);
  }
  .offer-card__tag--muted {
    background: transparent;
    color: var(--calm-earth);
    border: var(--border-soft);
  }

  /* Beide "anderen Wege" bewusst zurückgenommen, damit die eigene Lösung heraussticht */
  .offer-card--others {
    background: var(--bg);
    border: var(--border-soft);
    box-shadow: none;
  }
  .offer-card--others h3 {
    color: var(--calm-earth);
  }

  /* Die eigene Lösung steht in der Mitte und sitzt leicht erhöht;
     die beiden Außen-Karten bleiben tiefer auf Grundhöhe. */
  @media (min-width: 720px) {
    .offer-grid .offer-card {
      transition: transform 0.25s ease;
    }
    .offer-grid .offer-card--highlight {
      transform: translateY(-22px);
    }
  }

  /* Eigenes Angebot: klar hervorgehoben */
  .offer-card--highlight {
    background: var(--sage-harmony);
    border: 1px solid rgba(21, 44, 26, 0.25);
    box-shadow: var(--shadow-card);
  }

  .offer-list {
    list-style: none;
    margin: var(--space-md) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-xs);
  }
  .offer-list li {
    padding-left: 1.4em;
    position: relative;
  }
  .offer-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    font-weight: 700;
    color: var(--forest-deep);
  }
  /* Negativliste für den "üblichen Weg": ✕ statt ✓, gedämpft */
  .offer-list--cons li {
    color: var(--calm-earth);
  }
  .offer-list--cons li::before {
    content: '✕';
    color: var(--calm-earth);
  }

</style>

<script>
  // Themen-Slider: läuft automatisch von links nach rechts,
  // kann aber per Pfeilen, Punkten und Wischgeste auch manuell bedient werden.
  const slider = document.querySelector<HTMLElement>('[data-topic-slider]');
  if (slider) {
    const viewport = slider.querySelector<HTMLElement>('[data-viewport]')!;
    const track = slider.querySelector<HTMLElement>('[data-track]')!;
    const slides = Array.from(track.children) as HTMLElement[];
    const prevBtn = slider.querySelector<HTMLButtonElement>('[data-prev]')!;
    const nextBtn = slider.querySelector<HTMLButtonElement>('[data-next]')!;
    const dotsWrap = slider.querySelector<HTMLElement>('[data-dots]')!;

    const reduceMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;
    const AUTOPLAY_MS = 2800; // Auto-Lauf: startet früher / etwas zügiger
    const RESUME_MS = 10000; // nach eigener Bedienung 10 s warten

    let index = 0;
    let timer: ReturnType<typeof setInterval> | undefined;
    let resumeTimer: ReturnType<typeof setTimeout> | undefined;

    // Punkte aufbauen (einer pro Slide)
    const dots = slides.map((_, i) => {
      const dot = document.createElement('button');
      dot.type = 'button';
      dot.className = 'topic-slider__dot';
      dot.setAttribute('aria-label', `Thema ${i + 1} anzeigen`);
      dot.addEventListener('click', () => {
        goTo(i);
        scheduleResume();
      });
      dotsWrap.appendChild(dot);
      return dot;
    });

    function maxOffset() {
      return Math.max(0, track.scrollWidth - viewport.clientWidth);
    }

    // Größter Index, der noch sinnvoll anfahrbar ist (letzte Karte sichtbar)
    function lastIndex() {
      const max = maxOffset();
      for (let i = 0; i < slides.length; i++) {
        if (slides[i].offsetLeft >= max - 1) return i;
      }
      return slides.length - 1;
    }

    function goTo(i: number) {
      const last = lastIndex();
      if (i > last) i = 0; // am Ende wieder an den Anfang
      if (i < 0) i = last;
      index = i;
      const max = maxOffset();
      const x = Math.min(slides[i].offsetLeft, max);
      track.style.transform = `translateX(${-x}px)`;
      dots.forEach((d, di) =>
        d.setAttribute('aria-current', di === index ? 'true' : 'false')
      );
      // Fade ausblenden, sobald die letzte Karte voll sichtbar ist
      slider!.classList.toggle('is-end', x >= max - 1);
    }

    function next() {
      goTo(index + 1);
    }
    function prev() {
      goTo(index - 1);
    }

    function play() {
      if (resumeTimer) {
        clearTimeout(resumeTimer);
        resumeTimer = undefined;
      }
      if (reduceMotion || timer) return;
      timer = setInterval(next, AUTOPLAY_MS);
    }
    function stop() {
      if (timer) {
        clearInterval(timer);
        timer = undefined;
      }
    }
    // Nach eigener Bedienung erst nach RESUME_MS wieder automatisch laufen
    function scheduleResume() {
      stop();
      if (resumeTimer) clearTimeout(resumeTimer);
      if (reduceMotion) return;
      resumeTimer = setTimeout(play, RESUME_MS);
    }

    nextBtn.addEventListener('click', () => {
      next();
      scheduleResume();
    });
    prevBtn.addEventListener('click', () => {
      prev();
      scheduleResume();
    });

    // Pause bei Hover / Fokus; danach erst nach kurzer Wartezeit weiter
    slider.addEventListener('mouseenter', stop);
    slider.addEventListener('mouseleave', scheduleResume);
    slider.addEventListener('focusin', stop);
    slider.addEventListener('focusout', scheduleResume);

    // Wischgeste (Touch)
    let startX = 0;
    let dragging = false;
    viewport.addEventListener(
      'touchstart',
      (e) => {
        startX = e.touches[0].clientX;
        dragging = true;
        stop();
      },
      { passive: true }
    );
    viewport.addEventListener(
      'touchend',
      (e) => {
        if (!dragging) return;
        dragging = false;
        const dx = e.changedTouches[0].clientX - startX;
        if (Math.abs(dx) > 40) {
          dx < 0 ? next() : prev();
        }
        scheduleResume();
      },
      { passive: true }
    );

    // Bei Resize Position neu berechnen
    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => goTo(index), 150);
    });

    goTo(0);
    play();
  }
</script>
